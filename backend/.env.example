# ════════════════════════════════════════════
#   Ultrasonic Attendance System — Backend
#   Copy this file to .env and fill in values
# ════════════════════════════════════════════

# ── Server ───────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────
# Local MongoDB (development):
MONGODB_URI=mongodb://localhost:27017/ultrasonic_attendance

# MongoDB Atlas (production) — get from cloud.mongodb.com:
# MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/ultrasonic_attendance?retryWrites=true&w=majority

# ── Auth ─────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
# Generate one at: https://generate-secret.vercel.app/64
JWT_SECRET=change_this_to_a_very_long_random_secret_key_in_production
JWT_EXPIRES_IN=7d

# ── Frontend URL (CORS) ───────────────────────
# Development:
CLIENT_URL=http://localhost:5173

# Production (comma-separated if multiple):
# CLIENT_URL=https://your-app.vercel.app,https://your-custom-domain.com

# ── Deployment notes ──────────────────────────
# On Render.com, set all these as Environment Variables in the dashboard
# Set NODE_ENV=production on the server
