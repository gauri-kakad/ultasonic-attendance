# ════════════════════════════════════════════
#   Ultrasonic Attendance System — Backend
#   Copy this file to .env and fill in values
# ════════════════════════════════════════════

# ── Server ───────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────

# Local MongoDB (for development only)
MONGODB_URI=mongodb://localhost:27017/ultrasonic_attendance

# MongoDB Atlas (for production)
# Replace USERNAME and PASSWORD properly
# IMPORTANT: Do NOT use localhost in production
# Example:
# MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/ultrasonic_attendance?retryWrites=true&w=majority

# ── Auth ─────────────────────────────────────
# IMPORTANT: Always change this in production!
JWT_SECRET=your_super_secure_secret_key_here
JWT_EXPIRES_IN=7d

# ── Frontend URL (CORS) ───────────────────────

# Development:
CLIENT_URL=http://localhost:5173

# Production:
# Replace with your Vercel URL
# CLIENT_URL=https://your-app.vercel.app

# ── Deployment Notes ──────────────────────────

# On Render (Production):
# Set these in Render dashboard → Environment Variables

# REQUIRED:
# MONGODB_URI = your MongoDB Atlas connection string
# JWT_SECRET = strong secret
# NODE_ENV = production
# CLIENT_URL = your frontend URL
