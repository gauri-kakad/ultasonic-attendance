# Copy this to .env.development and .env.production
# Fill in your actual URLs

# For local development:
# VITE_API_URL=http://localhost:5000/api
# VITE_SOCKET_URL=http://localhost:5000

# For ngrok testing (update each time ngrok restarts):
# VITE_API_URL=https://your-ngrok-url.ngrok-free.app/api
# VITE_SOCKET_URL=https://your-ngrok-url.ngrok-free.app

# For production (Render backend + Vercel frontend):
# VITE_API_URL=https://your-app.onrender.com/api
# VITE_SOCKET_URL=https://your-app.onrender.com
